<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>

<GridPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.esprit.espritrestau.controllers.ModifyAbonnementController" hgap="10" vgap="10">
    <Label text="Date Début:" />
    <DatePicker fx:id="dateDebutField" promptText="Date Début" />

    <Label text="Date Fin:" />
    <DatePicker fx:id="dateFinField" promptText="Date Fin" />

    <Label text="Solde:" />
    <TextField fx:id="soldeField" promptText="Solde" />

    <Label text="ID Consommateur:" />
    <MenuButton fx:id="consommateurMenuButton" text="Choisir un Consommateur" />

    <Button text="Enregistrer" onAction="#saveAbonnement" />
    <Button text="Annuler" onAction="#cancel" />
</GridPane>