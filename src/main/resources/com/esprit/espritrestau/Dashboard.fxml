<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.shape.Arc?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/21.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.esprit.espritrestau.controllers.DashboardController">

    <children>
        <VBox alignment="CENTER" layoutX="100.0" layoutY="50.0" prefHeight="300.0" prefWidth="400.0" spacing="20.0" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="100.0" AnchorPane.rightAnchor="100.0" AnchorPane.topAnchor="50.0">
            <children>
                <Label text="Tableau de Bord - Effectifs">
                    <font>
                        <Font size="24.0" />
                    </font>
                </Label>
                <StackPane alignment="CENTER">
                    <children>
                        <Circle fx:id="baseCircle" radius="100.0" stroke="BLACK" strokeType="INSIDE">
                            <fill>
                                <Color fx:id="baseColor" red="0.941" green="0.941" blue="0.941" />
                            </fill>
                        </Circle>
                        <Arc fx:id="consumerArc" radiusX="100.0" radiusY="100.0" startAngle="90.0" length="0.0" type="ROUND">
                            <fill>
                                <Color fx:id="consumerColor" red="1.0" green="0.0" blue="0.0" />
                            </fill>
                        </Arc>
                        <Label fx:id="totalCountLabel" text="0">
                            <font>
                                <Font size="24.0" />
                            </font>
                            <textFill>
                                <Color red="0.0" green="0.0" blue="0.0" />
                            </textFill>
                        </Label>
                    </children>
                </StackPane>
                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Circle radius="8.0" fill="$consumerColor" />
                                <Label fx:id="consumerLabel" text="Consommateurs: 0" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <!-- Change fill to white and add a black stroke -->
                                <Circle fx:id="employeeColorIndicator" radius="8.0" fill="white" stroke="black" strokeWidth="1.0"/>
                                <Label fx:id="employeeLabel" text="Employés: 0">
                                    <textFill>
                                        <Color red="0.0" green="0.0" blue="0.0" />
                                    </textFill>
                                </Label>
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>