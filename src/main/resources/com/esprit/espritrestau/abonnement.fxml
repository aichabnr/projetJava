<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="802.0" prefWidth="1191.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.esprit.espritrestau.controllers.AbonnementController">

    <children>
        <TableView fx:id="tableAbonnements" layoutX="50.0" layoutY="355.0" prefHeight="374.0" prefWidth="1091.0" stylesheets="@../../../styles/style.css" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="244.0" text="ID" />
                <TableColumn fx:id="colDateDebut" prefWidth="205.0" text="Date Début" />
                <TableColumn fx:id="colDateFin" prefWidth="236.0" text="Date Fin" />
                <TableColumn fx:id="colSolde" prefWidth="206.0" text="Solde" />
                <TableColumn fx:id="colConsommateur" prefWidth="190.0" text="Consommateur" />
                <TableColumn fx:id="actionColumn" text="Actions" prefWidth="100.0" />
            </columns>
        </TableView>

        <HBox prefHeight="62.0" prefWidth="1191.0" style="-fx-background-color: gray;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />

        <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#ffffff00" height="114.0" layoutX="50.0" layoutY="141.0" stroke="#850f36" strokeType="INSIDE" width="1091.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" />

        <DatePicker fx:id="dateDebutInput" layoutX="121.0" layoutY="186.0" promptText="Date Début" stylesheets="@../../../styles/style.css" />
        <DatePicker fx:id="dateFinInput" layoutX="392.0" layoutY="186.0" promptText="Date Fin" stylesheets="@../../../styles/style.css" />
        <TextField fx:id="soldeInput" layoutX="663.0" layoutY="186.0" prefHeight="42.0" prefWidth="174.0" promptText="Solde Initial" stylesheets="@../../../styles/style.css" />
        <MenuButton fx:id="consommateurInput" layoutX="897.0" layoutY="186.0" mnemonicParsing="false" prefHeight="25.0" prefWidth="174.0" stylesheets="@../../../styles/style.css" text="Choisir un Consommateur" />

        <Button fx:id="createAbonButton" layoutX="534.0" layoutY="279.0" mnemonicParsing="false" onAction="#addAbonnement"
                prefHeight="30.0" prefWidth="150.0" stylesheets="@../../../styles/style.css" text="Créer Abonnement" />

        <TextField fx:id="searchIdInput" layoutX="50.0" layoutY="320.0" prefWidth="100.0" promptText="par ID" />
        <TextField fx:id="searchSoldeInput" layoutX="170.0" layoutY="320.0" prefWidth="100.0" promptText="par Solde" />
        <TextField fx:id="searchConsommateurInput" layoutX="290.0" layoutY="320.0" prefWidth="200.0" promptText="par Consommateur" />

        <Button fx:id="searchButton" layoutX="500.0" layoutY="320.0" onAction="#filterAbonnements"
