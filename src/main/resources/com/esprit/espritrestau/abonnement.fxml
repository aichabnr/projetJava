        <Button fx:id="downloadButton" layoutX="50.0" layoutY="270.0" mnemonicParsing="false" onAction="#downloadAbonnements"
                prefHeight="30.0" prefWidth="150.0" stylesheets="@../../../styles/style.css" text="Télécharger en PDF" />
        <Button fx:id="exportButton" layoutX="220.0" layoutY="270.0" mnemonicParsing="false" onAction="#exportToExcel"
                prefHeight="30.0" prefWidth="150.0" stylesheets="@../../../styles/style.css" text="Exporter en Excel" />
    </children>
