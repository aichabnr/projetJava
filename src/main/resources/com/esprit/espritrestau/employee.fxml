<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.esprit.espritrestau.controllers.EmployeeController">
    <Label text="Employee CRUD" styleClass="header-label" />

    <TextField fx:id="idField" promptText="ID" />
    <TextField fx:id="nomField" promptText="Name" />
    <TextField fx:id="prenomField" promptText="Surname" />
    <TextField fx:id="telField" promptText="Phone" />
    <TextField fx:id="postField" promptText="Post" />
    <TextField fx:id="matriculeField" promptText="Matricule Social" />
    <PasswordField fx:id="passwordField" promptText="Password" />

    <Button text="Save" onAction="#saveEmployee" />
    <Button text="Update" onAction="#updateEmployee" />
    <Button text="Delete" onAction="#deleteEmployee" />

    <ListView fx:id="employeeListView" />
</VBox>
