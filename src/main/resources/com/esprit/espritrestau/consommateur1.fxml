<AnchorPane fx:id="consommateurPane" prefHeight="400.0" prefWidth="600.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.esprit.espritrestau.controllers.ConsommateurControllerv1">
    <children>
        <TextField fx:id="txtNom" layoutX="154.0" layoutY="50.0" prefHeight="25.0" prefWidth="243.0" promptText="Nom" />
        <TextField fx:id="txtPrenom" layoutX="154.0" layoutY="100.0" prefHeight="25.0" prefWidth="243.0" promptText="Prenom" />
        <TextField fx:id="txtTel" layoutX="154.0" layoutY="150.0" prefHeight="25.0" prefWidth="243.0" promptText="Téléphone" />
        <TextField fx:id="txtPassword" layoutX="154.0" layoutY="200.0" prefHeight="25.0" prefWidth="243.0" promptText="Mot de Passe" />
        <TextField fx:id="txtType" layoutX="154.0" layoutY="250.0" prefHeight="25.0" prefWidth="243.0" promptText="Type" />
        <Button fx:id="btnAdd" layoutX="156.0" layoutY="300.0" mnemonicParsing="false" onAction="#addConsommateur" prefHeight="25.0" prefWidth="243.0" style="-fx-background-color: #4CAF50;" text="Ajouter" textFill="WHITE">
            <font>
                <Font name="Arial" size="12.0" />
            </font>
        </Button>
        <Button fx:id="btnUpdate" layoutX="156.0" layoutY="340.0" mnemonicParsing="false" onAction="#updateConsommateur" prefHeight="25.0" prefWidth="243.0" style="-fx-background-color: #2196F3;" text="Mettre à jour" textFill="WHITE">
            <font>
                <Font name="Arial" size="12.0" />
            </font>
        </Button>
        <Button fx:id="btnDelete" layoutX="156.0" layoutY="380.0" mnemonicParsing="false" onAction="#deleteConsommateur" prefHeight="25.0" prefWidth="243.0" style="-fx-background-color: #f44336;" text="Supprimer" textFill="WHITE">
            <font>
                <Font name="Arial" size="12.0" />
            </font>
        </Button>
        <Label fx:id="lblTitle" layoutX="28.0" layoutY="12.0" text="Gestion des Consommateurs" textFill="#fc1a1a">
            <font>
                <Font name="Arial Bold" size="16.0" />
            </font>
        </Label>
    </children>
</AnchorPane>
