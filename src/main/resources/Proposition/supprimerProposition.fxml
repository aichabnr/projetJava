<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="103.0" prefWidth="288.0" xmlns="http://javafx.com/javafx/21.0.6" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Proposition.SupprimerProposition">
        <Label fx:id="label" layoutX="23.0" layoutY="14.0" text="Voulez-vous supprimer cette proposition ?" />

        <!-- Boutons d'action -->
        <Button layoutX="54.0" layoutY="53.0" onAction="#handleConfirmButton" style="-fx-background-color: #850f36;" text="Confirmer" textFill="#f8f7f7" />
        <Button layoutX="155.0" layoutY="54.0" onAction="#handleCloseButton" prefHeight="25.0" prefWidth="69.0" style="-fx-background-color: #000000;" text="Annuler" textFill="WHITE" />
</AnchorPane>
