                <Button layoutX="9.0" layoutY="168.0" onAction="#openPersonnes" prefHeight="56.0" prefWidth="101.0" style="-fx-background-color: #E3AFBC; -fx-text-fill: #5D001E; -fx-font-weight: bold;" text="Personne" />
